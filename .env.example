# PostgreSQL container settings.
POSTGRES_DB=erp_system
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_pass1234

# Local Maven backend settings. Docker Compose builds the container DB URL from
# POSTGRES_DB/POSTGRES_USER/POSTGRES_PASSWORD instead.
DB_URL=jdbc:postgresql://localhost:5432/erp_system
DB_USER=erp_user
DB_PASS=erp_pass1234

# Local/demo only. Replace for shared, staging, and production deployments.
JWT_SECRET=ZmFrZS1kZW1vLXNlY3JldC1rZXktdGhhdC1tdXN0LWJlLTMyLWJ5dGVzLWxvbmc=
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

REDIS_HOST=redis
REDIS_PORT=6379

VITE_API_BASE_URL=http://localhost:8080
